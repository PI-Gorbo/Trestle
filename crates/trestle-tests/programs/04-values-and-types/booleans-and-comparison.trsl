// @skip: needs booleans + comparison/boolean operators (tier 04)
// TARGET: boolean literals and the operators that produce/combine them.

let yes = true
let no  = false

let isBigger = 5 > 3
let isEqual  = 2 + 2 == 4
let both     = isBigger && isEqual
let either   = isBigger || no
let negated  = !no
