// Trestle — Increment 1 (basics). Newlines are insignificant (structural statement delimiting).

WHITESPACE = _{ " " | "\t" | NEWLINE }
COMMENT    = _{ "//" ~ (!NEWLINE ~ ANY)* }

// lexical atoms
alphanumeric_word_boundary = @{ ASCII_ALPHANUMERIC | "_" }
alpha_word_boundary        = @{ ASCII_ALPHA | "_" }
let_kw                     = @{ "let" ~ !(alphanumeric_word_boundary) }

identifier                                = @{ !let_kw ~ (alpha_word_boundary) ~ (alphanumeric_word_boundary)* }
type_declaration                          =  { ":" ~ identifier }
optional_type_declaration                 =  { type_declaration? }
identifier_with_optional_type_declaration =  { identifier ~ (type_declaration)? }

// program & statements
program = { SOI ~ expr+ ~ EOI }

// expressions. Operator precedence is NOT encoded structurally here — the flat
// `binary_expression` rule hands its `primary`/operator sequence to a pest
// `PrattParser` (see build_expression.rs), which owns the precedence table.
int              = @{ ASCII_DIGIT+ }
string_character = @{ "\\" ~ ANY | !("\"" | "\\") ~ ANY }
string           = @{ "\"" ~ (string_character)* ~ "\"" }
float            = @{ int ~ "." ~ int }
true             = @{ "true" ~ !(alphanumeric_word_boundary) }
false            = @{ "false" ~ !(alphanumeric_word_boundary) }
boolean          =  { true | false }
literal          =  { boolean | string | float | int }

primary = { function_invocation | literal | identifier | "(" ~ expr ~ ")" }
// Prefix operators may stack before any primary (`--x`, `!!b`). They occupy a
// distinct grammar slot from the infix operators, so `negate`/`subtract` (both
// `-`) never collide: the PrattParser owns which one applies where.
binary_expression = { prefix_operator* ~ primary ~ (infix_operator ~ prefix_operator* ~ primary)* }

// Operator tokens. Silent group: PEG tries alternatives in order, so multi-char
// operators MUST precede the single-char ops they'd otherwise shadow (le before
// lt, ge before gt). Precedence/associativity live in the PrattParser, not here.
infix_operator = _{ and | or | add | subtract | multiply | divide | eq | neq | le | ge | lt | gt | pipe }
add            =  { "+" }
subtract       =  { "-" }
multiply       =  { "*" }
divide         =  { "/" }
and            =  { "&&" }
or             =  { "||" }
eq             =  { "==" }
neq            =  { "!=" }
le             =  { "<=" }
ge             =  { ">=" }
lt             =  { "<" }
gt             =  { ">" }
pipe           =  { "|>" }

// Prefix (unary) operators. `logical_not` lives only in this prefix slot, so the
// bare `!` never shadows infix `neq` (`!=`). `negate` is `-` in prefix position;
// binary `subtract` is `-` in infix position.
prefix_operator = _{ negate | logical_not }
negate          =  { "-" }
logical_not     =  { "!" }

// Params use the *optional*-type rule even though a type is required, so that the
// distinguishing `=>` lets this rule commit to the lambda branch instead of pest
// backtracking and reparsing `(n)` as a parenthesized expression. The missing type is
// then rejected in build_expression.rs (BuildError::MissingParamType) with a caret on
// the param — a far clearer error than the raw pest "expected EOI/operator" at `=>`.
lambda_expression                   = {
    "(" ~ (identifier_with_optional_type_declaration ~ ("," ~ identifier_with_optional_type_declaration)*)? ~ ")" ~ optional_type_declaration ~ "=>" ~ expr
}
comma_separated_list_of_expressions = { expr ~ ("," ~ expr)* }
function_invocation                 = { identifier ~ "(" ~ comma_separated_list_of_expressions? ~ ")" }
let_expression                      = { let_kw ~ identifier_with_optional_type_declaration ~ "=" ~ expr }
list_of_expressions                 = { "{" ~ expr+ ~ "}" }
if_expression                       = { "if" ~ "(" ~ expr ~ ")" ~ expr ~ ("else" ~ expr)? }

expr = { list_of_expressions | let_expression | lambda_expression | if_expression | binary_expression }
