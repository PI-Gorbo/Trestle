// @skip: needs ADTs + constructors + match (tiers 05/06) — PROPOSED syntax
// TARGET: sum types with constructors, consumed by pattern matching.

type Shape =
    | Circle { radius: Int }
    | Rectangle { width: Int, height: Int }

let area = (shape: Shape) =>
    match shape {
        Circle(r)        => 3 * r * r
        Rectangle(w, h)  => w * h
    }
