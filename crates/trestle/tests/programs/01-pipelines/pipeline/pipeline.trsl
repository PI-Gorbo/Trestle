// @skip: needs the |> operator + leading-pipe continuation (tier 01)
// Pipeline — the |> operator is "dumb": x |> f  ==  f(x)
// A line that begins with |> continues the previous expression
// (like Kotlin's leading `.`), so the chain needs no semicolons.

let add = (a: Int, b: Int) => a + b
let print = (value: Int) => value

let main =
    5
    |> add(3)    // add(3)(5)  = 8
    |> ((value: Int) => value * 2)
    |> print     // prints 16

main
