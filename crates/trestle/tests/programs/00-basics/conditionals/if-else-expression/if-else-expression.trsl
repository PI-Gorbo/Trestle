// @skip: needs if/else expressions (tier 00) — `if (cond) expr else expr`
// TARGET: the else form of the same construct — parenthesized condition, a then-expression,
// and an else-expression. Needs booleans + comparison (and subtraction for `0 - n`).

let abs = (n: Int) => if (n < 0) 0 - n else n
let bigger = (n: Int) =>
    if (n > 3)
        "Bigger"
    else
        "Smaller"

bigger(abs(-10))