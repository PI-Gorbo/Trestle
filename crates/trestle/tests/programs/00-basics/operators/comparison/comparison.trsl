// @skip: needs comparison operators + booleans (tier 00)
// TARGET: the six comparison operators, each taking two numbers and producing a Bool.
// Covers the full set (the old booleans test only exercised `>` and `==`).

let gt = 5 > 3
let lt = 3 < 5
let ge = 5 >= 5
let le = 3 <= 5
let eq = 2 + 2 == 4
let ne = 2 + 2 != 5
